{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "lib": ["ES2021"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@calley-ai/api/*": ["apps/api/src/*"],
      "@calley-ai/web/*": ["apps/web/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", ".next"]
}
